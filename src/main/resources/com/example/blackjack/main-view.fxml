<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.blackjack.BlackJackController">
   <children>
      <VBox fx:id="mainStage" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #1d522a;" visible="false">
         <children>
            <HBox  alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <HBox alignment="CENTER" prefHeight="89.0" prefWidth="66.0">
                     <children>
                        <Text fx:id="dealerScore" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-style: rgb(255 255 255 / 0);" text="Dealer Score" wrappingWidth="69.0">
                           <HBox.margin>
                              <Insets left="15.0" />
                           </HBox.margin></Text>
                     </children>
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </HBox>
                  <HBox fx:id="dealerCardsBox" prefHeight="100.0" prefWidth="200.0">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets></HBox>
               </children>
            </HBox>
            <VBox prefHeight="20.0" prefWidth="374.0" />
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <HBox alignment="CENTER" prefHeight="89.0" prefWidth="66.0">
                     <children>
                        <Text fx:id="playerScore" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Player Score:" wrappingWidth="67.0">
                           <HBox.margin>
                              <Insets left="15.0" />
                           </HBox.margin></Text>
                     </children>
                  </HBox>
                  <HBox fx:id="playerCardsBox" prefHeight="100.0" prefWidth="200.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button fx:id="hit" mnemonicParsing="false" onAction="#onHitClick" text="Hit">
                     <HBox.margin>
                     </HBox.margin>
                  </Button>
                  <Button fx:id="stand" mnemonicParsing="false" onAction="#onStandClick" text="Stand">
                     <HBox.margin>
                        <Insets left="15.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets top="20.0" />
         </padding>
      </VBox>
      <VBox fx:id="menu" alignment="TOP_CENTER" prefHeight="298.0" prefWidth="374.0" spacing="20.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="40.0" />
         </padding>
         <children>
            <Text fill="#ee0f0f" strokeType="OUTSIDE" strokeWidth="0.0" text="BlackJack" textAlignment="CENTER" wrappingWidth="75.3030014038086">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <font>
                  <Font name="C059-Bold" size="15.0" />
               </font>
            </Text>
            <Button mnemonicParsing="false" onAction="#onStartButtonClick" text="Start Game">
               <VBox.margin>
                  <Insets top="100.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </children>
</StackPane>
